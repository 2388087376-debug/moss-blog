// ----- Mobile slide-out nav (hidden on desktop) -----
#mobile-nav
  display: none

@media mq-mobile
  .mobile-nav-on
    #mobile-nav
      display: block
      position: fixed
      top: 0
      left: 0
      width: mobile-nav-width
      height: 100%
      background: #fff
      border-right: 1px solid #e5e5e7
      z-index: 0
      padding-top: 20px

    .mobile-nav-link
      display: block
      color: #1a1a1c
      text-decoration: none
      padding: 14px 20px
      font-size: 17px
      font-weight: 500
      &:hover
        background: #f5f5f5
