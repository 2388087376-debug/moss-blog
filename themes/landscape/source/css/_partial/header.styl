// ----- Header (mobile-first) -----
#header
  padding: 24px 0 48px 0

#header-inner
  display: flex
  align-items: center
  justify-content: space-between
  max-width: content-max-width
  margin: 0 auto
  padding: 0 mobile-padding
  box-sizing: border-box

#site-name
  font-size: 24px
  font-weight: 700
  color: #1a1a1c
  text-decoration: none
  letter-spacing: -0.3px
  line-height: 1

#main-nav
  display: none

.main-nav-link
  text-decoration: none
  font-size: 16px
  font-weight: 400
  color: #6e6e73
  transition: color 0.15s
  &:hover
    color: #1a1a1c

// ----- Hamburger -----
#nav-toggle
  display: flex
  flex-direction: column
  gap: 5px
  cursor: pointer
  padding: 4px 0
  z-index: 101
  span
    display: block
    width: 20px
    height: 2px
    background: #1a1a1c
    border-radius: 1px

// ----- Mobile dropdown -----
#mobile-dropdown
  display: none
  position: fixed
  top: 56px
  right: mobile-padding
  background: #fff
  border: 1px solid #e5e5e7
  border-radius: 14px
  padding: 8px 0
  z-index: 200
  min-width: 160px
  box-shadow: 0 4px 24px rgba(0,0,0,0.08)
  a
    display: block
    padding: 12px 24px
    color: #1a1a1c
    text-decoration: none
    font-size: 17px
    &:hover
      background: #f5f5f5

#nav-check:checked ~ #mobile-dropdown
  display: block

// ----- Desktop -----
@media mq-normal
  #header
    padding: 48px 0 64px 0

  #header-inner
    align-items: baseline

  #site-name
    font-size: 42px

  #main-nav
    display: flex
    gap: 36px

  #nav-toggle
    display: none

  #mobile-dropdown
    display: none !important
