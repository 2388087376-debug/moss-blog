// ----- Latest Posts heading -----
#latest-posts
  font-size: 16px
  font-weight: 500
  color: #6e6e73
  letter-spacing: 0.5px
  margin: 0 0 20px 0
  padding: 0

// ----- Archive pages -----
.archives-wrap
  margin: block-margin 0

.archives
  clearfix()

.archive-year-wrap
  margin-bottom: 16px

.archive-year
  @extend $block-caption
  font-size: 17px
  color: #6e6e73

.archive-article-inner
  @extend $block
  padding: 20px 24px
  margin-bottom: block-margin
  box-sizing: border-box
  transition: box-shadow 0.15s
  &:hover
    box-shadow: 0 2px 12px rgba(0,0,0,0.03)

.archive-article-title
  text-decoration: none
  font-size: 20px
  font-weight: 600
  color: #1a1a1c
  line-height: 1.4
  display: block
  &:hover
    opacity: 0.6

.archive-article-footer
  margin-top: 8px

.archive-article-date
  color: #6e6e73
  text-decoration: none
  font-size: 16px
  line-height: 1em
  display: block

// ----- Pagination -----
#page-nav
  clearfix()
  margin: block-margin 0
  display: flex
  gap: 8px
  a, span
    padding: 10px 18px
    line-height: 1
    border-radius: 8px
    font-size: 15px
  a
    color: #6e6e73
    text-decoration: none
    background: #fff
    border: 1px solid #e5e5e7
    &:hover
      background: #f5f5f5
      color: #1a1a1c
  .page-number
    @media mq-mobile
      display: none
  .current
    color: #1a1a1c
    background: #f5f5f5
    border: 1px solid #e5e5e7
  .space
    display: none
