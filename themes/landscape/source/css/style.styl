@import "nib"
@import "_variables"
@import "_util/mixin"
@import "_util/grid"

global-reset()

input, button
  margin: 0
  padding: 0
  &::-moz-focus-inner
    border: 0
    padding: 0

html
  overflow-x: hidden

body
  overflow-x: hidden
  min-height: 100vh
  background: url('/images/bg-page.jpg') center/cover no-repeat scroll
  font: font-size font-sans
  color: color-default
  -webkit-text-size-adjust: 100%
  -webkit-font-smoothing: antialiased
  -moz-osx-font-smoothing: grayscale

.outer
  max-width: content-max-width
  margin: 0 auto
  padding: 0 mobile-padding
  box-sizing: border-box

.inner
  width: 100%

.left, .alignleft
  float: left

.right, .alignright
  float: right

.clear
  clear: both

#container
  position: relative

.mobile-nav-on
  overflow: hidden

#wrap
  min-height: 100vh
  width: 100%
  position: relative
  transition: transform 0.2s ease-out
  z-index: 1
  .mobile-nav-on &
    transform: translateX(mobile-nav-width)

#main
  width: 100%
  box-sizing: border-box

// mobile: subtle bg with white overlay for readability
@media mq-mobile
  body
    background: linear-gradient(rgba(255,255,255,0.75), rgba(255,255,255,0.75)), url('/images/bg-page.jpg') center top/cover no-repeat scroll

@import "_extend"
@import "_partial/header"
@import "_partial/article"
@import "_partial/comment"
@import "_partial/archive"
@import "_partial/footer"
@import "_partial/highlight"
@import "_partial/mobile"
